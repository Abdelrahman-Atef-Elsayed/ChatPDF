# Copy this file to .env and fill in any keys you want to use.
# Any provider can also be selected at runtime via the sidebar.

# --- Cloud LLM providers (all optional; app also works fully offline) ---
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
TOGETHER_API_KEY=

# --- Local LLM via Ollama (https://ollama.com) ---
# Start the server with: ollama serve
# Pull a model with:    ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Optional tuning ---
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# REQUEST_TIMEOUT=60
# DATA_DIR=data
